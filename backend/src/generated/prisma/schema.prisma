generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STUDENT
  ACCOUNTS
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  MOBILE_CREDIT_CARD
}

enum SchoolLevel {
  PRIMARY
  SECONDARY
  TERTIARY
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VerificationStatus {
  UNVERIFIED
  VERIFIED
  FLAGGED
}

enum ReconciliationStatus {
  UNMATCHED
  MATCHED
}

enum ReminderCampaignStatus {
  ACTIVE
  PAUSED
}

enum ReminderScheduleType {
  DAILY
  WEEKLY
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  passwordHash       String
  firstName          String?
  lastName           String?
  role               UserRole           @default(STUDENT)
  status             UserStatus         @default(ACTIVE)
  profilePictureUrl  String?
  currentSessionId   String?
  sessionExpires     DateTime?
  lastLoginAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  student            Student?
  verifiedPayments   Payment[]          @relation("PaymentVerifier")
  reviewedPayments   Payment[]          @relation("PaymentReviewer")
  reconciledPayments Payment[]          @relation("PaymentReconciler")
  statementImports   StatementImport[]
  reminderCampaigns  ReminderCampaign[]
  generatedReports   GeneratedReport[]
  notifications      Notification[]
  auditLogs          AuditLog[]         @relation("AuditLogActor")
  sentMessages       Message[]          @relation("SentMessages")
  receivedMessages   Message[]          @relation("ReceivedMessages")
  reactions          Reaction[]
}

model Student {
  id             String      @id @default(cuid())
  userId         String      @unique
  studentCode    String      @unique
  firstName      String
  lastName       String
  program        String
  classLevel     String?
  academicYear   String?
  term           String?
  semester       String?
  schoolLevel    SchoolLevel @default(TERTIARY)
  phone          String?
  currentBalance Decimal     @default(0) @db.Decimal(12, 2)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments       Payment[]
}

model FeeStructure {
  id           String      @id @default(cuid())
  title        String
  description  String?
  amount       Decimal     @db.Decimal(12, 2)
  program      String?
  classLevel   String?
  term         String?
  semester     String?
  academicYear String?
  schoolLevel  SchoolLevel @default(TERTIARY)
  dueDate      DateTime?
  feeType      String? // 'tuition' | 'hostel' | 'exam' | 'library' | 'other'
  active       Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Payment {
  id                   String               @id @default(cuid())
  studentId            String
  amount               Decimal              @db.Decimal(12, 2)
  currency             String               @default("MWK")
  method               PaymentMethod
  externalReference    String?
  receiptNumber        String?
  proofUrl             String
  payerName            String?
  paymentDate          DateTime
  submittedAt          DateTime             @default(now())
  status               PaymentStatus        @default(PENDING)
  verificationStatus   VerificationStatus   @default(UNVERIFIED)
  duplicateFlag        Boolean              @default(false)
  ocrText              String?
  ocrAmount            Decimal?             @db.Decimal(12, 2)
  ocrReference         String?
  notes                String?
  verificationNotes    String?
  reviewNotes          String?
  reconciliationStatus ReconciliationStatus @default(UNMATCHED)
  reconciliationNote   String?
  reconciledAt         DateTime?
  reconciledBy         String?
  verifiedBy           String?
  verifiedAt           DateTime?
  reviewedAt           DateTime?
  reviewerId           String?
  academicYear         String?
  term                 String?
  semester             String?
  student              Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  reconciler           User?                @relation("PaymentReconciler", fields: [reconciledBy], references: [id], onDelete: SetNull)
  verifier             User?                @relation("PaymentVerifier", fields: [verifiedBy], references: [id], onDelete: SetNull)
  reviewer             User?                @relation("PaymentReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([studentId, status])
  @@index([externalReference])
  @@index([receiptNumber])
  @@index([academicYear, term])
  @@index([academicYear, semester])
}

model StatementImport {
  id            String               @id @default(cuid())
  fileName      String
  uploadedBy    String
  uploadedAt    DateTime             @default(now())
  headers       String[]
  totalRows     Int                  @default(0)
  totalAmount   Decimal              @default(0) @db.Decimal(12, 2)
  summary       Json
  columnMapping Json?
  user          User                 @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)
  rows          StatementImportRow[]

  @@index([uploadedBy, uploadedAt])
}

model StatementImportRow {
  id                    String          @id @default(cuid())
  importId              String
  rowNumber             Int
  rawData               Json
  reference             String?
  payerName             String?
  description           String?
  amount                Decimal?        @db.Decimal(12, 2)
  transactionDate       DateTime?
  matchState            String
  suggestions           Json
  resolvedPaymentId     String?
  autoApprovedPaymentId String?
  reconciledAt          DateTime?
  statementImport       StatementImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@index([importId, rowNumber])
}

model ReminderCampaign {
  id               String                 @id @default(cuid())
  name             String
  status           ReminderCampaignStatus @default(ACTIVE)
  scheduleType     ReminderScheduleType
  dayOfWeek        Int?
  sendHour         Int
  sendMinute       Int                    @default(0)
  minBalance       Decimal?               @db.Decimal(12, 2)
  maxBalance       Decimal?               @db.Decimal(12, 2)
  titleTemplate    String
  messageTemplate  String
  targetStudentIds Json?
  createdBy        String
  lastRunAt        DateTime?
  nextRunAt        DateTime
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  user             User                   @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([status, nextRunAt])
  @@index([createdBy, createdAt])
}

model GeneratedReport {
  id          String   @id @default(cuid())
  title       String
  reportType  String // e.g., 'TERMLY', 'MONTHLY', 'ANNUAL', 'CUSTOM'
  filters     Json // The filter criteria used to generate it
  data        Json? // Snapshot of the data at that time
  generatedBy String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [generatedBy], references: [id], onDelete: Cascade)

  @@index([generatedBy])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String // e.g., 'FEE_ASSIGNED', 'PAYMENT_SUBMITTED', 'PAYMENT_APPROVED', 'SYSTEM'
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model AuditLog {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())
  action      String
  actorUserId String?
  actorEmail  String?
  actorRole   String?
  ipAddress   String?
  userAgent   String?
  sessionId   String?
  targetType  String?
  targetId    String?
  status      String   @default("SUCCESS")
  reason      String?
  details     Json?
  actorUser   User?    @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([timestamp])
  @@index([action, timestamp])
  @@index([actorUserId, timestamp])
}

model SystemRegistry {
  id              String   @id @default("singleton")
  institutionName String   @default("Unregistered School")
  institutionType String   @default("Primary School")
  address         String?
  logoUrl         String?
  contactEmail    String?
  updatedAt       DateTime @updatedAt
}

model Message {
  id          String    @id @default(cuid())
  senderId    String
  receiverId  String
  content     String
  read        Boolean   @default(false)
  readAt      DateTime?
  delivered   Boolean   @default(false)
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())

  // Reply/Quote functionality
  replyToId String?
  replyTo   Message?  @relation("ReplyTo", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[] @relation("ReplyTo")

  // File attachment
  attachmentUrl  String?
  attachmentName String?
  attachmentSize String?
  attachmentType String?

  // Reactions
  reactions Reaction[]

  // Edit tracking
  edited   Boolean   @default(false)
  editedAt DateTime?

  // Soft delete
  deleted   Boolean   @default(false)
  deletedAt DateTime?

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([senderId, receiverId])
  @@index([replyToId])
}

model Reaction {
  id        String   @id @default(cuid())
  emoji     String
  messageId String
  userId    String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@index([userId])
}
