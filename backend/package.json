{
    "name": "edupaytrack-backend",
    "version": "1.0.0",
    "description": "Backend for EduPayTrack",
    "main": "dist/index.js",
    "private": true,
    "scripts": {
        "start": "node dist/index.js",
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "build": "tsc",
        "start:prod": "npm run build && npm start",
        "prisma:generate": "prisma generate",
        "prisma:push": "prisma db push",
        "prisma:migrate": "prisma migrate dev",
        "admin:bootstrap": "node scripts/bootstrap-admin.js",
        "seed:demo": "node scripts/seed-demo.js"
    },
    "dependencies": {
        "@prisma/client": "^6.5.0",
        "@types/pdfkit": "^0.17.5",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.6.1",
        "express": "^4.19.2",
        "jsonwebtoken": "^9.0.2",
        "multer": "^2.1.1",
        "pdfkit": "^0.18.0",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.9",
        "@types/multer": "^2.1.0",
        "@types/node": "^20.14.9",
        "prisma": "^6.5.0",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.5.3"
    }
}
